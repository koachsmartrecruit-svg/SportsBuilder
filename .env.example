# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=development

# Database
# Development: SQLite
DATABASE_URL=sqlite:///sportsbuilder.db
# Production: PostgreSQL (example)
# DATABASE_URL=postgresql://user:password@localhost:5432/sportsbuilder

# AWS S3 Storage (Optional - for production file uploads)
USE_S3_STORAGE=false
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=sportsbuilder-uploads
AWS_S3_REGION_NAME=ap-southeast-1

# Email Service (Optional - for transactional emails)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@sportsbuilder.com
FROM_NAME=SportsBuilder

# Site Configuration
SITE_URL=http://localhost:5000

# Redis (Optional - for rate limiting in production)
REDIS_URL=redis://localhost:6379/0
